# ── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_token_here
TELEGRAM_WEBHOOK_SECRET=your_webhook_secret
TELEGRAM_WEBHOOK_URL=https://your-domain.com/webhook
# Base URL for automatic webhook registration on startup (e.g. https://your-domain.com).
# Leave empty in local development — the gateway will start without registering a webhook.
WEBHOOK_BASE_URL=

# ── RabbitMQ ──────────────────────────────────────────────────────────────────
RABBITMQ_USER=verum
RABBITMQ_PASS=verum_pass
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_QUEUE_IMAGES=topic_images
RABBITMQ_QUEUE_TEXTS=topic_texts
RABBITMQ_CONNECT_MAX_RETRIES=10

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_USER=verum
MONGO_PASS=verum_pass
MONGO_HOST=mongodb
MONGO_PORT=27017
MONGO_DB=verum
MONGO_COLLECTION_QUERIES=queries

# ── Qdrant ────────────────────────────────────────────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=fact_checks

# ── Ollama ────────────────────────────────────────────────────────────────────
OLLAMA_HOST=ollama
OLLAMA_PORT=11434
OLLAMA_MODEL=qwen2.5:14b-instruct-q4_K_M          # or qwen2.5:1.5b for lower-memory envs
# Timeout (segundos) para inferencia de Ollama. Subir para modelos grandes en CPU
# (un 14B puede tardar 2-4 min por respuesta). Default 600s = 10 min.
OLLAMA_TIMEOUT_SECONDS=600

# ── External APIs ─────────────────────────────────────────────────────────────
GOOGLE_FACT_CHECK_API_KEY=your_key_here
GNEWS_API_KEY=your_key_here

# ── NLP config ────────────────────────────────────────────────────────────────
NLP_MIN_TEXT_LENGTH=50            # Messages shorter than this are ignored
EMBEDDING_MODEL=BAAI/bge-m3
NLP_TOPIC_OVERLAP_MIN=0.30        # raised from 0.15 — discard topic-tangential hits before LLM

# ── RAG pipeline thresholds ───────────────────────────────────────────────
NLP_CONFIDENCE_THRESHOLD=0.65    # raised from 0.55 — LLM now mediates, can afford stricter L1 gate
NLP_MIN_ARTICLE_SCORE=0.35       # Minimum score to use best local hit as last resort (raised to reduce false-positive verdicts from weakly-related articles)
# ── ETL scheduler ───────────────────────────────────────────────────
ETL_SCHEDULE=0 */12 * * *         # Cron expression for automatic ETL runs (default: every 12 h)

# ── Seed classic hoaxes ───────────────────────────────────────────────────────
# Seed initial classic hoaxes on first ETL run if Qdrant is empty.
# Set to 'true' to force re-seeding on every run.
SEED_CLASSICS=true

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_MAX_REQUESTS=10        # Max requests per user per window
RATE_LIMIT_WINDOW_SECONDS=60      # Window duration in seconds

# ── Vision config ─────────────────────────────────────────────────────────────
VISION_MODEL_PATH=/app/weights/verum_cnn.onnx
VISION_CONFIDENCE_THRESHOLD=0.80
